# ─────────────────────────────────────────────────────────
# SchedulerAI — Environment Variables
# Copy this file to backend/.env and fill in the values
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
TIMEZONE=America/New_York

# ── AI Provider ───────────────────────────────────────────
# Options: groq | openai | claude | gemini
AI_PROVIDER=groq

# ── Provider API Keys (only the active one is required) ───
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-pro

# ── Google Calendar OAuth2 ────────────────────────────────
# Get credentials from: https://console.cloud.google.com/
# Enable the Google Calendar API, then create OAuth 2.0 credentials
# Add http://localhost:3001/api/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Zoom OAuth (optional — required only when Zoom is selected as meeting platform) ─
# Create a User-managed OAuth app at https://marketplace.zoom.us/develop/create
# App type: OAuth (NOT Server-to-Server)
# Grant scopes: meeting:write  meeting:read  user:read
# Add redirect URI: http://localhost:3001/api/auth/zoom/callback
ZOOM_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOOM_REDIRECT_URI=http://localhost:3001/api/auth/zoom/callback
